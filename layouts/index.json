{{- $pages := where site.RegularPages "Section" "in" (slice "blog" "projects" "slides" "certifications") -}}
[
{{- range $index, $page := $pages -}}
  {{- if $index }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "url": {{ $page.RelPermalink | jsonify }},
    "section": {{ $page.Section | jsonify }},
    "date": {{ $page.Date.Format "2006-01-02" | jsonify }},
    "summary": {{ (or $page.Params.deck ($page.Summary | plainify)) | jsonify }},
    "tags": {{ $page.Params.tags | jsonify }},
    "playlists": {{ $page.Params.playlists | jsonify }}
  }
{{- end }}
]
